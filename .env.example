# Backend reads this at startup (see backend/app.py load_env_file)

# =============================
# LaunchBox Integration
# =============================
# Set LaunchBox plugin HTTP bridge port
LB_PLUGIN_PORT=10099

# =============================
# Supabase Cloud Integration
# =============================
# Supabase project URL (from supabase.com project settings)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe for client-side use)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (NEVER expose to clients, backend only)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# =============================
# AI Services
# =============================
# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_API_KEY=sk-ant-...

# OpenAI API (GPT fallback)
OPENAI_API_KEY=sk-...

# Google AI (Gemini)
GOOGLE_API_KEY=...

# ElevenLabs API (Text-to-Speech)
ELEVENLABS_API_KEY=...
# Voice profile for Doc (optional override of default)
DOC_VOICE_ID=your-doc-voice-id

# =============================
# System Configuration
# =============================
# Root path for local operations
AA_DRIVE_ROOT=A:\

# Gateway port
PORT=8787

# Backend URL (8000 via npm script, 8888 via direct Python)
FASTAPI_URL=http://localhost:8888

# Environment mode
NODE_ENV=development

# Log level
LOG_LEVEL=info

# =============================
# Feature Flags
# =============================
# Controller Auto-Configuration Feature Flag
# Set to 'true' to enable USB controller auto-detection and profile mirroring
# Default: false (disabled for safety until capsule self-tests pass)
CONTROLLER_AUTOCONFIG_ENABLED=false

# Frontend feature flag (Vite environment variable)
# Must match backend setting for consistent UX
VITE_CONTROLLER_AUTOCONFIG_ENABLED=false
