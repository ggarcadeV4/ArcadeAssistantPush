{
  "emulator_type": "teknoparrot",
  "display_name": "TeknoParrot",
  "supported_players": 2,
  "logical_inputs": [
    "p1.up", "p1.down", "p1.left", "p1.right",
    "p1.button1", "p1.button2", "p1.button3", "p1.button4",
    "p1.button5", "p1.button6", "p1.button7", "p1.button8",
    "p1.start", "p1.coin", "p1.test", "p1.service",
    "p1.gas", "p1.brake", "p1.wheel", "p1.shiftup", "p1.shiftdown",
    "p1.gun_trigger", "p1.gun_reload"
  ],
  "config_files": [
    "UserProfiles/*.xml"
  ],
  "config_locations": {
    "game_profiles": "TeknoParrot\\TeknoParrotUi.Common\\GameProfiles\\",
    "user_profiles": "TeknoParrot\\UserProfiles\\",
    "retrobat_mapping": "\\system\\resources\\inputmapping\\teknoparrot.yml"
  },
  "config_format": "xml",
  "input_apis": ["XInput", "DirectInput", "RawInput"],
  "notes": "Per-game configuration required. No global controller config. Each game needs individual setup via UI.",
  "key_differences": [
    "No Global Config - each game needs individual controller setup",
    "XML-Based - uses XML for all configuration (not INI)",
    "Per-Game Input API - input method selected per-game",
    "JVS Emulation - emulates arcade JVS I/O boards",
    "UI-Driven - primarily configured via UI"
  ],
  "button_mapping": {
    "button1": "Button1",
    "button2": "Button2",
    "button3": "Button3",
    "button4": "Button4",
    "button5": "Button5",
    "button6": "Button6",
    "button7": "Button7",
    "button8": "Button8"
  },
  "special_controls": {
    "start": "Start",
    "coin": "Coin",
    "up": "Up",
    "down": "Down",
    "left": "Left",
    "right": "Right",
    "test": "Test",
    "service": "Service"
  },
  "racing_controls": {
    "gas": "GasAxis",
    "brake": "BrakeAxis",
    "wheel": "WheelAxis",
    "shiftup": "ShiftUp",
    "shiftdown": "ShiftDown",
    "viewchange": "ViewChange",
    "handbrake": "HandBrake"
  },
  "lightgun_controls": {
    "p1_gun_x": "P1GunX",
    "p1_gun_y": "P1GunY",
    "p2_gun_x": "P2GunX",
    "p2_gun_y": "P2GunY",
    "gun_trigger": "GunTrigger",
    "gun_reload": "GunReload",
    "gun_pump": "GunPump"
  },
  "retrobat_button_values": {
    "face_buttons": ["south", "east", "west", "north"],
    "triggers": ["righttrigger", "lefttrigger", "rightshoulder", "leftshoulder"],
    "sticks": ["r3", "l3"],
    "menu": ["select", "start"],
    "dpad": ["up", "down", "left", "right"],
    "left_stick": ["leftstickleft", "leftstickright", "leftstickup", "leftstickdown"],
    "right_stick": ["rightstickleft", "rightstickright", "rightstickup", "rightstickdown"],
    "lightgun": ["mouseleft", "mousemiddle", "mouseright", "button4", "button5"]
  },
  "special_settings": {
    "stOOz_zone": {
      "description": "Joystick deadzone percentage",
      "recommended": "16-20%",
      "notes": "Reduces twitchiness in racing games, not recommended for steering wheels"
    },
    "reverse_axis": {
      "description": "Inverts pedal axis if car accelerates/brakes when pedals not pressed"
    },
    "separate_pedal_axes": {
      "description": "Check if wheel has separate axis per pedal"
    }
  },
  "lightgun_setup": {
    "input_api": "RawInput (must be selected in GAME SETTINGS)",
    "max_guns": 2,
    "sinden": "Disable offscreen reload in Sinden software",
    "dolphinbar": "Mode 2 for RawInput, Mode 3 for DirectInput"
  },
  "command_line": {
    "launch_profile": "TeknoParrotUi.exe --profile=<profile.xml>",
    "start_minimized": "TeknoParrotUi.exe --startMinimized",
    "jvs_only": "TeknoParrotUi.exe --emuonly"
  },
  "common_issues": {
    "per_game_config": "Each game requires separate controller setup",
    "input_api_selection": "Must choose correct Input API (XInput vs DirectInput) per game",
    "xml_management": "UserProfile XML must exist before game launches",
    "retrobat_overwrite": "RetroBat may overwrite UserProfile if not configured properly"
  },
  "references": {
    "official_guide": "https://teknoparrot.com/wiki/getstarted.html",
    "github": "https://github.com/teknogods/TeknoParrotUI",
    "retrobat_wiki": "https://wiki.retrobat.org/controllers/specific_mapping/teknoparrot-controller-mapping"
  }
}
