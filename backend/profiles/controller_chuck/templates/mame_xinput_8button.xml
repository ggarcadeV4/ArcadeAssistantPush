<!-- 
  MAME Controller Configuration File
  Generated by Controller Chuck

  Profile: 8-Button Arcade Layout (XInput Mode)
  Encoder: PaCTo Tech or Ultimarc I-PAC (in XInput Mode)

  This file maps a full 8-button layout using XInput joystick codes.
  This corresponds to the standard Xbox 360/One controller layout, including the triggers.

  To use this file:
  1. Save it as `8button_layout_xinput.cfg` in your MAME `ctrlr` directory.
  2. In your mame.ini file, set `ctrlr` to `8button_layout_xinput`.
  3. Ensure `-joystickprovider dinput` is set in your mame.ini.
-->

<mameconfig version="10">
  <system name="default">
    <input>
      <!-- Player 1 Controls (mapped from Joy 1) -->
      <port type="P1_JOYSTICK_UP">
        <newseq type="standard">JOYCODE_1_YAXIS_UP_SWITCH</newseq>
      </port>
      <port type="P1_JOYSTICK_DOWN">
        <newseq type="standard">JOYCODE_1_YAXIS_DOWN_SWITCH</newseq>
      </port>
      <port type="P1_JOYSTICK_LEFT">
        <newseq type="standard">JOYCODE_1_XAXIS_LEFT_SWITCH</newseq>
      </port>
      <port type="P1_JOYSTICK_RIGHT">
        <newseq type="standard">JOYCODE_1_XAXIS_RIGHT_SWITCH</newseq>
      </port>
      <port type="P1_BUTTON1">
        <newseq type="standard">JOYCODE_1_BUTTON1</newseq> <!-- A Button -->
      </port>
      <port type="P1_BUTTON2">
        <newseq type="standard">JOYCODE_1_BUTTON2</newseq> <!-- B Button -->
      </port>
      <port type="P1_BUTTON3">
        <newseq type="standard">JOYCODE_1_BUTTON3</newseq> <!-- X Button -->
      </port>
      <port type="P1_BUTTON4">
        <newseq type="standard">JOYCODE_1_BUTTON4</newseq> <!-- Y Button -->
      </port>
      <port type="P1_BUTTON5">
        <newseq type="standard">JOYCODE_1_BUTTON5</newseq> <!-- Left Bumper -->
      </port>
      <port type="P1_BUTTON6">
        <newseq type="standard">JOYCODE_1_BUTTON6</newseq> <!-- Right Bumper -->
      </port>
      <port type="P1_BUTTON7">
        <newseq type="standard">JOYCODE_1_ZAXIS_NEG_SWITCH</newseq> <!-- Left Trigger -->
      </port>
      <port type="P1_BUTTON8">
        <newseq type="standard">JOYCODE_1_ZAXIS_POS_SWITCH</newseq> <!-- Right Trigger -->
      </port>

      <!-- Player 2 Controls (mapped from Joy 2) -->
      <port type="P2_JOYSTICK_UP">
        <newseq type="standard">JOYCODE_2_YAXIS_UP_SWITCH</newseq>
      </port>
      <port type="P2_JOYSTICK_DOWN">
        <newseq type="standard">JOYCODE_2_YAXIS_DOWN_SWITCH</newseq>
      </port>
      <port type="P2_JOYSTICK_LEFT">
        <newseq type="standard">JOYCODE_2_XAXIS_LEFT_SWITCH</newseq>
      </port>
      <port type="P2_JOYSTICK_RIGHT">
        <newseq type="standard">JOYCODE_2_XAXIS_RIGHT_SWITCH</newseq>
      </port>
      <port type="P2_BUTTON1">
        <newseq type="standard">JOYCODE_2_BUTTON1</newseq>
      </port>
      <port type="P2_BUTTON2">
        <newseq type="standard">JOYCODE_2_BUTTON2</newseq>
      </port>
      <port type="P2_BUTTON3">
        <newseq type="standard">JOYCODE_2_BUTTON3</newseq>
      </port>
      <port type="P2_BUTTON4">
        <newseq type="standard">JOYCODE_2_BUTTON4</newseq>
      </port>
      <port type="P2_BUTTON5">
        <newseq type="standard">JOYCODE_2_BUTTON5</newseq>
      </port>
      <port type="P2_BUTTON6">
        <newseq type="standard">JOYCODE_2_BUTTON6</newseq>
      </port>
      <port type="P2_BUTTON7">
        <newseq type="standard">JOYCODE_2_ZAXIS_NEG_SWITCH</newseq>
      </port>
      <port type="P2_BUTTON8">
        <newseq type="standard">JOYCODE_2_ZAXIS_POS_SWITCH</newseq>
      </port>

      <!-- System Controls (mapped from Joy 1) -->
      <port type="UI_SELECT">
        <newseq type="standard">JOYCODE_1_BUTTON7</newseq> <!-- Back/Select Button -->
      </port>
      <port type="UI_CANCEL">
        <newseq type="standard">KEYCODE_ESC</newseq>
      </port>
      <port type="UI_CONFIGURE">
        <newseq type="standard">KEYCODE_TAB</newseq>
      </port>
      <port type="START1">
        <newseq type="standard">JOYCODE_1_BUTTON8</newseq> <!-- Start Button -->
      </port>
      <port type="START2">
        <newseq type="standard">JOYCODE_2_BUTTON8</newseq>
      </port>
      <port type="COIN1">
        <newseq type="standard">JOYCODE_1_BUTTON7</newseq>
      </port>
      <port type="COIN2">
        <newseq type="standard">JOYCODE_2_BUTTON7</newseq>
      </port>
    </input>
  </system>
</mameconfig>
