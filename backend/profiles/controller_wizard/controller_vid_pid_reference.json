  "connection_types": {
    "USB": {
      "reliability": "Most reliable",
      "latency": "Lowest",
      "notes": "Plug-and-play, VID/PID remains consistent"
    },
    "Bluetooth": {
      "reliability": "Good",
      "latency": "Higher than USB",
      "notes": "May have different PID than USB version, requires Bluetooth stack"
    },
    "Wireless Adapter": {
      "reliability": "Good",
      "latency": "Lower than Bluetooth",
      "notes": "Proprietary protocol, requires specific dongle"
    }
  },
  "input_apis": {
    "XInput": {
      "platforms": ["Windows"],
      "notes": "Native Xbox support, limited button mapping flexibility",
      "supported_controllers": ["Xbox 360", "Xbox One", "Xbox Series", "XInput-mode third-party"]
    },
    "DirectInput": {
      "platforms": ["Windows"],
      "notes": "More flexible, requires per-game configuration",
      "supported_controllers": ["PlayStation (via DS4Windows)", "Logitech F-series", "Generic USB"]
    },
    "SDL": {
      "platforms": ["Windows", "Linux", "Mac"],
      "notes": "Cross-platform, used by Dolphin, RetroArch",
      "requires": "Device name or GUID"
    },
    "evdev": {
      "platforms": ["Linux"],
      "notes": "Linux-native controller support"
    }
  },
  "guid_formats": {
    "windows_dinput": {
      "format": "{XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}",
      "notes": "Based on VID/PID and device instance"
    },
    "sdl": {
      "format": "03000000VVVVPPPP0000000000000000",
      "notes": "VVVV = Vendor ID (hex), PPPP = Product ID (hex)",
      "example": "030000005e040000ea020000ff0f0000 (Xbox 360)"
    }
  },
  "controller_behaviors": {
    "xbox": {
      "features": ["Native XInput on Windows", "Consistent button layout", "Analog triggers", "Rumble standard"]
    },
    "playstation": {
      "features": ["Require third-party drivers on Windows", "Touchpad (DS4/DualSense)", "Motion controls", "Analog triggers (DualSense)"]
    },
    "nintendo": {
      "features": ["Require special drivers/adapters", "Joy-Cons can be individual or paired", "Motion controls", "Digital triggers only"]
    },
    "arcade": {
      "features": ["Usually DirectInput", "May lack analog triggers", "Button numbering varies", "Requires manual mapping"]
    }
  },
