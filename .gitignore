# ============================================
# Arcade Assistant - Git Ignore Configuration
# CODE ONLY - No ROMs, ISOs, BIOS, or large assets
# ============================================

# ---------------------------
# ROMs, ISOs, BIOS - NEVER COMMIT THESE
# ---------------------------
*.iso
*.ISO
*.bin
*.BIN
*.rom
*.ROM
*.cue
*.CUE
*.gdi
*.GDI
*.chd
*.CHD
*.zip
*.7z
*.rar
**/Roms/
**/ROMs/
**/roms/
**/Bios/
**/BIOS/
**/bios/
**/_tmp/
**/Console ROMs/

# ---------------------------
# Environment & Secrets (NEVER commit these!)
# ---------------------------
.env
.env.backup
.env.win
.env.wsl
# Keep these template files:
# .env.example
# .env.template

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
.pytest_cache/
*.egg-info/
.eggs/
*.egg

# ---------------------------
# Node.js
# ---------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

