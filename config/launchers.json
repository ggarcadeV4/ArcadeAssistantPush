{
    "global": {
        "allow_direct_retroarch": true,
        "allow_direct_mame": true,
        "allow_direct_pcsx2": true,
        "allow_direct_teknoparrot": true,
        "allow_direct_cemu": true,
        "allow_direct_model2": true,
        "qol": {
            "skip_nags": true,
            "cheats_enabled": false
        },
        "allow_direct_rpcs3": true,
        "allow_direct_supermodel": true
    },
    "emulators": {
        "retroarch": {
            "exe": "${AA_DRIVE_ROOT}/Emulators/RetroArch/retroarch.exe",
            "platform_map": {
                "Atari 2600":                           "stella",
                "Atari 7800":                           "prosystem",
                "Nintendo Entertainment System":        "mesen",
                "Super Nintendo Entertainment System":  "snes9x",
                "Sega Genesis":                         "genesis_plus_gx",
                "Nintendo Game Boy":                    "gambatte",
                "Nintendo Game Boy Advance":            "mgba",
                "Nintendo Game Boy Color":              "gambatte",
                "Sega Game Gear":                       "genesis_plus_gx",
                "Sega Master System":                   "genesis_plus_gx",
                "Atari Lynx":                           "handy",
                "Atari Jaguar":                         "virtualjaguar",
                "NEC TurboGrafx-16":                    "mednafen_pce_fast",
                "Sega 32X":                             "picodrive",
                "Sega CD":                              "genesis_plus_gx",
                "Sony Playstation":                     "mednafen_psx_hw",
                "Neo Geo Pocket":                       "mednafen_ngp",
                "Neo Geo Pocket Color":                 "mednafen_ngp",
                "WonderSwan":                           "mednafen_wswan",
                "WonderSwan Color":                     "mednafen_wswan"
            },
            "cores": {
                "stella":            "cores/stella_libretro.dll",
                "prosystem":         "cores/prosystem_libretro.dll",
                "mesen":             "cores/mesen_libretro.dll",
                "snes9x":            "cores/snes9x_libretro.dll",
                "genesis_plus_gx":   "cores/genesis_plus_gx_libretro.dll",
                "gambatte":          "cores/gambatte_libretro.dll",
                "mgba":              "cores/mgba_libretro.dll",
                "handy":             "cores/handy_libretro.dll",
                "virtualjaguar":     "cores/virtualjaguar_libretro.dll",
                "mednafen_pce_fast": "cores/mednafen_pce_fast_libretro.dll",
                "picodrive":         "cores/picodrive_libretro.dll",
                "mednafen_psx_hw":   "cores/mednafen_psx_hw_libretro.dll",
                "mednafen_ngp":      "cores/mednafen_ngp_libretro.dll",
                "mednafen_wswan":    "cores/mednafen_wswan_libretro.dll"
            },
            "flags": ["-f"]
        },
        "mame": {
            "exe": "${AA_DRIVE_ROOT}/Emulators/MAME/mame.exe",
            "rompath": "${AA_DRIVE_ROOT}/Roms/MAME",
            "platforms": ["Arcade", "Arcade MAME", "MAME Gun Games"],
            "flags": ["-skip_gameinfo"]
        },
        "teknoparrot": {
            "exe": "${AA_DRIVE_ROOT}/Emulators/TeknoParrot Latest/TeknoParrotUi.exe",
            "platforms": ["TeknoParrot Arcade", "Taito Type X"]
        },
        "pcsx2": {
            "exe": "${AA_DRIVE_ROOT}/LaunchBox/Emulators/PCSX2/pcsx2-qt.exe",
            "platforms": ["Sony Playstation 2", "PS2", "PS2 Gun Games"],
            "flags": []
        },
        "model2": {
            "exe": "${AA_DRIVE_ROOT}/Emulators/Sega Model 2/EMULATOR.EXE",
            "platforms": ["Sega Model 2"],
            "flags": []
        },
        "cemu": {
            "exe": "${AA_DRIVE_ROOT}/LaunchBox/Emulators/cemu_1.26.2/Cemu.exe",
            "platforms": ["Nintendo Wii U"],
            "flags": ["-f", "-g"]
        },
        "dolphin": {
            "exe": "${AA_DRIVE_ROOT}/LaunchBox/Emulators/dolphin-2412-x64/Dolphin-x64/Dolphin.exe",
            "platforms": ["Nintendo GameCube", "Nintendo Wii"],
            "flags": []
        },
        "rpcs3": {
            "exe": "${AA_DRIVE_ROOT}/LaunchBox/Emulators/rpcs3/rpcs3.exe",
            "platforms": ["Sony Playstation 3", "PS3"],
            "flags": []
        },
        "hypseus": {
            "exe": "${AA_DRIVE_ROOT}/Emulators/Hypseus/Hypseus Singe/hypseus.exe",
            "platforms": ["Daphne", "Hypseus", "Laserdisc"],
            "flags": []
        }
    }
}
