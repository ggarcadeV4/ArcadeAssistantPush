# Arcade Assistant – Environment Template (Drive A)
#
# Copy this file to .env and fill in the required values below.
# Do NOT commit your filled .env to source control.

# Core ports
PORT=8787
FASTAPI_URL=http://127.0.0.1:8888

# Supabase (Option A: service_role on device)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=<REQUIRED: https://YOUR-PROJECT.supabase.co>
SUPABASE_ANON_KEY=<REQUIRED: anon public key>
SUPABASE_SERVICE_KEY=<REQUIRED: service_role secret>

# Cabinet identity (unique per cabinet)
# Use a UUID that matches public.devices.id in Supabase
AA_DEVICE_ID=<REQUIRED: per-cabinet UUID>
# Optional friendly identifiers (used by installer)
DEVICE_SERIAL=<REQUIRED: e.g., AA-0001>
DEVICE_NAME=<OPTIONAL: e.g., Basement Cabinet 1>

# Drive A path (keep as A:\ on Windows)
AA_DRIVE_ROOT=A:\

# Optional feature flags (safe defaults)
AA_BACKUP_ON_WRITE=true
AA_DRY_RUN_DEFAULT=false
AA_PRELOAD_LB_CACHE=true

# Optional: AI providers (leave blank if unused)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=

# Notes:
# - Keep this file (.env) local to each cabinet. Do NOT commit secrets.
# - AA_DEVICE_ID should also be written to /.aa/cabinet_manifest.json
# - After setting values, launch: start-aa-dev.bat
